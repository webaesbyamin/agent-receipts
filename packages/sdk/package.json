{
  "name": "@agentreceipts/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Agent Receipts — local-first action tracking",
  "license": "MIT",
  "author": "Amin <amin@webaes.co> (https://webaes.co)",
  "repository": {
    "type": "git",
    "url": "https://github.com/webaesbyamin/agent-receipts",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/webaesbyamin/agent-receipts#readme",
  "bugs": {
    "url": "https://github.com/webaesbyamin/agent-receipts/issues"
  },
  "keywords": [
    "agent-receipts",
    "sdk",
    "ai-agents",
    "action-tracking",
    "receipts",
    "verification",
    "typescript"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentreceipts/schema": "workspace:*",
    "@agentreceipts/crypto": "workspace:*",
    "@agentreceipts/mcp-server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.2.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
