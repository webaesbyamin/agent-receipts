{
  "name": "@agentreceipts/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Agent Receipts API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo 'SDK tests will be added in Phase 3'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentreceipts/schema": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.2.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
