{
  "name": "@agent-receipts/mcp-server",
  "version": "0.3.2",
  "mcpName": "io.github.webaesbyamin/agent-receipts",
  "type": "module",
  "description": "Local-first MCP server for Agent Receipts — storage, engine, and protocol",
  "license": "MIT",
  "author": "Amin <amin@webaes.co> (https://webaes.co)",
  "repository": {
    "type": "git",
    "url": "https://github.com/webaesbyamin/agent-receipts",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/webaesbyamin/agent-receipts#readme",
  "bugs": {
    "url": "https://github.com/webaesbyamin/agent-receipts/issues"
  },
  "keywords": [
    "agent-receipts",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "receipts",
    "signing",
    "verification",
    "claude",
    "cursor"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "agent-receipts-server": "./dist/server.js",
    "mcp-server": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-receipts/crypto": "workspace:*",
    "@agent-receipts/schema": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.8.0",
    "nanoid": "^5.1.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "tsup": "^8.2.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
