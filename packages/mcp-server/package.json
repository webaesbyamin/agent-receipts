{
  "name": "@agentreceipts/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first MCP server for Agent Receipts — storage, engine, and protocol",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "agent-receipts-server": "./dist/server.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentreceipts/schema": "workspace:*",
    "@agentreceipts/crypto": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "nanoid": "^5.1.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.2.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
