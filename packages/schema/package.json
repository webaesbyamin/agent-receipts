{
  "name": "@agent-receipts/schema",
  "version": "0.3.3",
  "description": "Zod schemas and TypeScript types for the Action Receipt Protocol",
  "license": "MIT",
  "author": "Amin <amin@webaes.co> (https://webaes.co)",
  "repository": {
    "type": "git",
    "url": "https://github.com/webaesbyamin/agent-receipts",
    "directory": "packages/schema"
  },
  "homepage": "https://github.com/webaesbyamin/agent-receipts#readme",
  "bugs": {
    "url": "https://github.com/webaesbyamin/agent-receipts/issues"
  },
  "keywords": [
    "agent-receipts",
    "action-receipt-protocol",
    "zod",
    "schema",
    "validation",
    "ai-agents",
    "mcp"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "receipt.schema.json"
  ],
  "scripts": {
    "build": "tsup && node -e \"const{zodToJsonSchema}=require('zod-to-json-schema');const{ActionReceipt}=require('./dist');const fs=require('fs');fs.writeFileSync('receipt.schema.json',JSON.stringify(zodToJsonSchema(ActionReceipt,'ActionReceipt'),null,2));\"",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.2.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0",
    "zod-to-json-schema": "^3.23.0"
  }
}
